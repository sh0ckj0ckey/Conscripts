<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Conscripts.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Conscripts.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:Microsoft.UI.Xaml.Controls"
    xmlns:animations="using:CommunityToolkit.WinUI.Animations"
    xmlns:converters="using:Conscripts.Converters"
    xmlns:viewmodels="using:Conscripts.ViewModels"
    mc:Ignorable="d">

    <Page.Resources>
        <converters:Bool2VisibilityConverter x:Key="Bool2VisibilityConverter"/>
        <converters:BoolNegationConverter x:Key="BoolNegationConverter"/>
        <converters:Enum2ColorConverter x:Key="Enum2ColorConverter"/>
        <converters:Color2BorderThicknessConverter x:Key="Color2BorderThicknessConverter"/>
        <converters:Category2SeperateLineConverter x:Key="Category2SeperateLineConverter"/>
        <converters:Equal2VisibilityConverter x:Key="Equal2VisibilityConverter"/>
        <converters:Unequal2VisibilityConverter x:Key="Unequal2VisibilityConverter"/>
    </Page.Resources>

    <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
        <ScrollViewer HorizontalScrollMode="Disabled" VerticalScrollMode="Auto" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <controls:ItemsRepeater Margin="20,0,20,20" ItemsSource="{x:Bind ViewModel.ShortcutGroups,Mode=OneWay}">
                <controls:ItemsRepeater.Layout>
                    <controls:StackLayout Orientation="Vertical"/>
                </controls:ItemsRepeater.Layout>
                <DataTemplate x:DataType="viewmodels:ShortcutGroupViewModel">
                    <Grid HorizontalAlignment="Stretch">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Margin="-20,24,-20,16" Visibility="{x:Bind Category,Converter={StaticResource Category2SeperateLineConverter}}" HorizontalAlignment="Stretch" VerticalAlignment="Center">
                            <Border Height="1" Background="{ThemeResource ControlElevationBorderBrush}" HorizontalAlignment="Stretch" VerticalAlignment="Center"/>
                        </Border>

                        <TextBlock Grid.Row="0" FontSize="16" Margin="12,16,0,12" FontWeight="Bold" Text="{x:Bind Category}" Visibility="{x:Bind Category,Converter={StaticResource Category2SeperateLineConverter},ConverterParameter=!}" TextTrimming="CharacterEllipsis" HorizontalAlignment="Left" VerticalAlignment="Center"/>

                        <controls:ItemsRepeater Grid.Row="1" ItemsSource="{x:Bind Shortcuts,Mode=OneWay}">
                            <controls:ItemsRepeater.Layout>
                                <controls:UniformGridLayout Orientation="Horizontal" MinItemWidth="156" MinItemHeight="96" MinColumnSpacing="8" MinRowSpacing="8" ItemsStretch="Uniform"/>
                            </controls:ItemsRepeater.Layout>
                            <DataTemplate x:DataType="viewmodels:ShortcutItemViewModel">
                                <Grid CornerRadius="4" Background="{x:Bind Color,Mode=OneWay,Converter={StaticResource Enum2ColorConverter}}">
                                    <Button Padding="0" Background="Transparent" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Stretch" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                                            DataContext="{x:Bind }" IsEnabled="{x:Bind IsRunning,Mode=OneWay,Converter={StaticResource BoolNegationConverter}}" 
                                            BorderThickness="{x:Bind Color,Mode=OneWay,Converter={StaticResource Color2BorderThicknessConverter}}" ToolTipService.ToolTip="{x:Bind Name,Mode=OneWay}"
                                            Click="Button_Click" ContextRequested="Button_ContextRequested">
                                        <Button.Resources>
                                            <MenuFlyout x:Key="ShortcutMenuFlyout" Placement="Bottom">
                                                <MenuFlyoutItem x:Name="FrontMenuItem" x:Uid="ShortcutFrontMenuItem" Tag="front" Click="FrontMenuItem_Click">
                                                    <MenuFlyoutItem.Icon>
                                                        <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xEA4F;"/>
                                                    </MenuFlyoutItem.Icon>
                                                </MenuFlyoutItem>
                                                <MenuFlyoutItem x:Name="LeftMenuItem" x:Uid="ShortcutLeftMenuItem" Tag="left" Click="LeftMenuItem_Click">
                                                    <MenuFlyoutItem.Icon>
                                                        <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xE64E;"/>
                                                    </MenuFlyoutItem.Icon>
                                                </MenuFlyoutItem>
                                                <MenuFlyoutItem x:Name="RightMenuItem" x:Uid="ShortcutRightMenuItem" Tag="right" Click="RightMenuItem_Click">
                                                    <MenuFlyoutItem.Icon>
                                                        <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xE64D;"/>
                                                    </MenuFlyoutItem.Icon>
                                                </MenuFlyoutItem>
                                                <MenuFlyoutItem x:Name="InfoMenuItem" x:Uid="ShortcutPropertiesMenuItem" Tag="properties" Click="InfoMenuItem_Click">
                                                    <MenuFlyoutItem.Icon>
                                                        <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xE90F;"/>
                                                    </MenuFlyoutItem.Icon>
                                                </MenuFlyoutItem>
                                                <MenuFlyoutSeparator/>
                                                <MenuFlyoutItem x:Name="DeleteMenuItem" x:Uid="ShortcutDeleteMenuItem" Tag="delete" Click="DeleteMenuItem_Click">
                                                    <MenuFlyoutItem.Icon>
                                                        <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xE74D;"/>
                                                    </MenuFlyoutItem.Icon>
                                                </MenuFlyoutItem>
                                            </MenuFlyout>
                                        </Button.Resources>
                                        <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                            <TextBlock FontSize="38" Opacity="0.5" Margin="0,0,8,8" Text="{x:Bind Icon,Mode=OneWay}" FontFamily="{ThemeResource SymbolThemeFontFamily}" HorizontalAlignment="Right" VerticalAlignment="Bottom"/>

                                            <TextBlock FontSize="14" Foreground="White" Margin="12,12,12,12" FontWeight="Bold" Text="{x:Bind Name,Mode=OneWay}" 
                                                       TextWrapping="Wrap" TextTrimming="CharacterEllipsis" MaxLines="2" HorizontalAlignment="Left" VerticalAlignment="Top"
                                                       Visibility="{x:Bind Color,Mode=OneWay,Converter={StaticResource Unequal2VisibilityConverter},ConverterParameter=Transparent}"/>
                                            <TextBlock FontSize="14" Margin="12,12,12,12" FontWeight="Bold" Text="{x:Bind Name,Mode=OneWay}" 
                                                       TextWrapping="Wrap" TextTrimming="CharacterEllipsis" MaxLines="2" HorizontalAlignment="Left" VerticalAlignment="Top"
                                                       Visibility="{x:Bind Color,Mode=OneWay,Converter={StaticResource Equal2VisibilityConverter},ConverterParameter=Transparent}"/>

                                            <StackPanel Orientation="Horizontal" Margin="12,8" Spacing="8" HorizontalAlignment="Left" VerticalAlignment="Bottom">
                                                <FontIcon x:Uid="ShortcutRunasIcon" Glyph="&#xEA18;" Visibility="{x:Bind RunAsAdministrator,Mode=OneWay,Converter={StaticResource Bool2VisibilityConverter}}" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" Opacity="0.5"/>
                                                <FontIcon x:Uid="ShortcutNewWindowIcon" Glyph="&#xF7ED;" Visibility="{x:Bind RunWithoutWindow,Mode=OneWay,Converter={StaticResource Bool2VisibilityConverter},ConverterParameter=!}" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" Opacity="0.5"/>
                                            </StackPanel>
                                        </Grid>
                                    </Button>

                                    <!--Running Indicator-->
                                    <Border Visibility="{x:Bind IsRunning,Mode=OneWay,Converter={StaticResource Bool2VisibilityConverter}}" Background="{ThemeResource SmokeFillColorDefault}" CornerRadius="4" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                        <ProgressRing IsActive="{x:Bind IsRunning,Mode=OneWay}" Foreground="White" Height="32" Width="32" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </controls:ItemsRepeater>
                    </Grid>
                </DataTemplate>
            </controls:ItemsRepeater>
        </ScrollViewer>

        <Grid x:Name="SettingsGrid" Opacity="0" Visibility="Collapsed" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="{ThemeResource SmokeFillColorDefault}">
            <animations:Implicit.ShowAnimations>
                <animations:OpacityAnimation To="1" Duration="0:0:0.4"/>
            </animations:Implicit.ShowAnimations>
            <animations:Implicit.HideAnimations>
                <animations:OpacityAnimation To="0" Duration="0:0:0.2"/>
            </animations:Implicit.HideAnimations>
            <Grid CornerRadius="6" BorderThickness="1" BorderBrush="{ThemeResource ControlElevationBorderBrush}" Background="{ThemeResource AcrylicBackgroundFillColorBaseBrush}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="72" MaxWidth="680">
                <animations:Implicit.ShowAnimations>
                    <animations:TranslationAnimation From="0,32,0" To="0,0,0" EasingMode="EaseInOut" EasingType="Default" Duration="0:0:0.4"/>
                </animations:Implicit.ShowAnimations>
                <animations:Implicit.HideAnimations>
                    <animations:TranslationAnimation To="0,32,0" EasingMode="EaseInOut" EasingType="Default" Duration="0:0:0.2"/>
                </animations:Implicit.HideAnimations>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock x:Uid="SettingsTitleTextBlock" Margin="24,16,0,16" FontWeight="Bold" FontSize="20"/>
                <Button Height="38" Width="38" Padding="0" Margin="0,0,20,0" Background="Transparent" BorderBrush="Transparent" 
                        HorizontalAlignment="Right" VerticalAlignment="Center" Click="CloseSettings_Click">
                    <FontIcon Glyph="&#xE624;" FontSize="18" FontFamily="{ThemeResource SymbolThemeFontFamily}"/>
                </Button>
                <Border x:Name="SettingsBorder" Grid.Row="1" BorderBrush="{ThemeResource ControlElevationBorderBrush}" BorderThickness="0,1,0,0"/>
            </Grid>
        </Grid>

        <Grid x:Name="WhatsNewGrid" Opacity="0" Visibility="Collapsed" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="{ThemeResource SmokeFillColorDefault}">
            <animations:Implicit.ShowAnimations>
                <animations:OpacityAnimation To="1" Duration="0:0:0.4"/>
            </animations:Implicit.ShowAnimations>
            <animations:Implicit.HideAnimations>
                <animations:OpacityAnimation To="0" Duration="0:0:0.2"/>
            </animations:Implicit.HideAnimations>
            <Grid CornerRadius="6" BorderThickness="1" BorderBrush="{ThemeResource ControlElevationBorderBrush}" Background="{ThemeResource AcrylicBackgroundFillColorBaseBrush}" HorizontalAlignment="Stretch" VerticalAlignment="Center" Margin="72" MaxWidth="540">
                <animations:Implicit.ShowAnimations>
                    <animations:TranslationAnimation From="0,32,0" To="0,0,0" EasingMode="EaseInOut" EasingType="Default" Duration="0:0:0.4"/>
                </animations:Implicit.ShowAnimations>
                <animations:Implicit.HideAnimations>
                    <animations:TranslationAnimation To="0,32,0" EasingMode="EaseInOut" EasingType="Default" Duration="0:0:0.2"/>
                </animations:Implicit.HideAnimations>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock x:Uid="WhatsNewTitleTextBlock" Margin="24,16,0,16" FontWeight="Bold" FontSize="20"/>
                <Button Height="38" Width="38" Padding="0" Margin="0,0,20,0" Background="Transparent" BorderBrush="Transparent" 
                        HorizontalAlignment="Right" VerticalAlignment="Center" Click="CloseWhatsNew_Click">
                    <FontIcon Glyph="&#xE624;" FontSize="18" FontFamily="{ThemeResource SymbolThemeFontFamily}"/>
                </Button>
                <Border x:Name="WhatsNewBorder" Grid.Row="1" BorderBrush="{ThemeResource ControlElevationBorderBrush}" BorderThickness="0,1,0,0"/>
            </Grid>
        </Grid>

        <Grid x:Name="AddingGrid" Opacity="0" Visibility="Collapsed" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="{ThemeResource SmokeFillColorDefault}">
            <animations:Implicit.ShowAnimations>
                <animations:OpacityAnimation To="1" Duration="0:0:0.4"/>
            </animations:Implicit.ShowAnimations>
            <animations:Implicit.HideAnimations>
                <animations:OpacityAnimation To="0" Duration="0:0:0.2"/>
            </animations:Implicit.HideAnimations>
            <Grid CornerRadius="6" BorderThickness="1" BorderBrush="{ThemeResource ControlElevationBorderBrush}" Background="{ThemeResource AcrylicBackgroundFillColorBaseBrush}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="72">
                <animations:Implicit.ShowAnimations>
                    <animations:TranslationAnimation From="0,32,0" To="0,0,0" EasingMode="EaseInOut" EasingType="Default" Duration="0:0:0.4"/>
                </animations:Implicit.ShowAnimations>
                <animations:Implicit.HideAnimations>
                    <animations:TranslationAnimation To="0,32,0" EasingMode="EaseInOut" EasingType="Default" Duration="0:0:0.2"/>
                </animations:Implicit.HideAnimations>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock x:Uid="AddTitleTextBlock" Margin="24,16,0,16" FontWeight="Bold" FontSize="20"/>
                <Button Height="38" Width="38" Padding="0" Margin="0,0,20,0" Background="Transparent" BorderBrush="Transparent" 
                        HorizontalAlignment="Right" VerticalAlignment="Center" Click="CloseAdding_Click">
                    <FontIcon Glyph="&#xE624;" FontSize="18" FontFamily="{ThemeResource SymbolThemeFontFamily}"/>
                </Button>
                <Border x:Name="AddingBorder" Grid.Row="1" BorderBrush="{ThemeResource ControlElevationBorderBrush}" BorderThickness="0,1,0,0"/>
            </Grid>
        </Grid>

        <Grid x:Name="PropertyGrid" Opacity="0" Visibility="Collapsed" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="{ThemeResource SmokeFillColorDefault}">
            <animations:Implicit.ShowAnimations>
                <animations:OpacityAnimation To="1" Duration="0:0:0.4"/>
            </animations:Implicit.ShowAnimations>
            <animations:Implicit.HideAnimations>
                <animations:OpacityAnimation To="0" Duration="0:0:0.2"/>
            </animations:Implicit.HideAnimations>
            <Grid CornerRadius="6" BorderThickness="1" BorderBrush="{ThemeResource ControlElevationBorderBrush}" Background="{ThemeResource AcrylicBackgroundFillColorBaseBrush}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Margin="72" MaxWidth="420">
                <animations:Implicit.ShowAnimations>
                    <animations:TranslationAnimation From="0,32,0" To="0,0,0" EasingMode="EaseInOut" EasingType="Default" Duration="0:0:0.4"/>
                </animations:Implicit.ShowAnimations>
                <animations:Implicit.HideAnimations>
                    <animations:TranslationAnimation To="0,32,0" EasingMode="EaseInOut" EasingType="Default" Duration="0:0:0.2"/>
                </animations:Implicit.HideAnimations>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock x:Uid="PropertiesTitleTextBlock" Margin="24,16,0,16" FontWeight="Bold" FontSize="20"/>
                <Button Height="38" Width="38" Padding="0" Margin="0,0,20,0" Background="Transparent" BorderBrush="Transparent" 
                        HorizontalAlignment="Right" VerticalAlignment="Center" Click="CloseProperty_Click">
                    <FontIcon Glyph="&#xE624;" FontSize="18" FontFamily="{ThemeResource SymbolThemeFontFamily}"/>
                </Button>
                <Border x:Name="PropertyBorder" Grid.Row="1" BorderBrush="{ThemeResource ControlElevationBorderBrush}" BorderThickness="0,1,0,0"/>
            </Grid>
        </Grid>
    </Grid>
</Page>
