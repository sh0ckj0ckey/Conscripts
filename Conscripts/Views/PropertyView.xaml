<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Conscripts.Views.PropertyView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Conscripts.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:icon="using:NoMewing.SegoeFluentIcons"
    mc:Ignorable="d"
    Loaded="UserControl_Loaded">

    <UserControl.Resources>
        <Style x:Key="NoPaddingFlyoutPresenterStyle"
               TargetType="FlyoutPresenter"
               BasedOn="{StaticResource DefaultFlyoutPresenterStyle}">
            <Setter Property="Padding" Value="0" />
        </Style>
    </UserControl.Resources>

    <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <ScrollViewer x:Name="PropertyScrollViewer" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" HorizontalScrollMode="Disabled" VerticalScrollMode="Auto" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                <StackPanel Orientation="Vertical" Margin="20">
                    <Grid x:Name="CardPreviewGrid" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                        <TextBlock FontSize="38" Opacity="0.5" Margin="0,0,8,8" Text="{x:Bind Icon,Mode=OneWay}" FontFamily="{ThemeResource SymbolThemeFontFamily}" HorizontalAlignment="Right" VerticalAlignment="Bottom"/>

                        <TextBlock FontSize="14" Foreground="White" Margin="12,12,12,12" FontWeight="Bold" Text="{x:Bind Name,Mode=OneWay}" 
                                   TextWrapping="Wrap" TextTrimming="CharacterEllipsis" MaxLines="2" HorizontalAlignment="Left" VerticalAlignment="Top"
                                   Visibility="{x:Bind Color,Mode=OneWay,Converter={StaticResource Unequal2VisibilityConverter},ConverterParameter=Transparent}"/>
                        <TextBlock FontSize="14" Margin="12,12,12,12" FontWeight="Bold" Text="{x:Bind Name,Mode=OneWay}" 
                                   TextWrapping="Wrap" TextTrimming="CharacterEllipsis" MaxLines="2" HorizontalAlignment="Left" VerticalAlignment="Top"
                                   Visibility="{x:Bind Color,Mode=OneWay,Converter={StaticResource Equal2VisibilityConverter},ConverterParameter=Transparent}"/>

                        <StackPanel Orientation="Horizontal" Margin="12,8" Spacing="8" HorizontalAlignment="Left" VerticalAlignment="Bottom">
                            <FontIcon x:Uid="ShortcutRunasIcon" Glyph="&#xEA18;" Visibility="{x:Bind RunAsAdministrator,Mode=OneWay,Converter={StaticResource Bool2VisibilityConverter}}" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" Opacity="0.5"/>
                            <FontIcon x:Uid="ShortcutNewWindowIcon" Glyph="&#xF7ED;" Visibility="{x:Bind RunWithoutWindow,Mode=OneWay,Converter={StaticResource Bool2VisibilityConverter},ConverterParameter=!}" FontFamily="{ThemeResource SymbolThemeFontFamily}" FontSize="14" Opacity="0.5"/>
                        </StackPanel>
                    </Grid>

                    <Border Height="8"/>
                    
                    <Grid ColumnSpacing="16" Padding="16,8,8,8" BorderThickness="1,1,1,0" CornerRadius="8,8,0,0" HorizontalAlignment="Stretch" VerticalAlignment="Top"
                          Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="2*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Uid="AddingShortcutIconTextBlock" FontSize="14" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                        <Button x:Name="AddingShortcutIconButton" Grid.Column="1" Content="&#xE756;" Padding="0" Height="48" Width="48" FontSize="18" FontFamily="{ThemeResource SymbolThemeFontFamily}" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Button.Flyout>
                                <Flyout x:Name="AddingShortcutIconsFlyout" Placement="Left" FlyoutPresenterStyle="{StaticResource NoPaddingFlyoutPresenterStyle}">
                                    <Grid Background="Transparent" Padding="0" Width="300" Height="216">
                                        <GridView x:Name="AddingShortcutIconsGridView" Padding="4" SelectionMode="None" IsItemClickEnabled="True" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" 
                                                  Loaded="AddingShortcutIconsGridView_Loaded" ItemClick="AddingShortcutIconsGridView_ItemClick">
                                            <GridView.ItemTemplate>
                                                <DataTemplate x:DataType="icon:IconInfo">
                                                    <Grid Width="34" Height="34">
                                                        <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="{x:Bind Glyph}" ToolTipService.ToolTip="{x:Bind Name}" FontSize="16"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </GridView.ItemTemplate>
                                        </GridView>
                                    </Grid>
                                </Flyout>
                            </Button.Flyout>
                        </Button>
                    </Grid>
                    <Grid ColumnSpacing="16" Padding="16,8,8,8" BorderThickness="1,1,1,0" CornerRadius="0,0,0,0" HorizontalAlignment="Stretch" VerticalAlignment="Top"
                          Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="2*" MaxWidth="232"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Uid="AddingShortcutNameTextBlock" FontSize="14" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                        <TextBox x:Name="AddingShortcutNameTextBox" Grid.Column="1" PlaceholderText="" FontSize="14" Height="34" HorizontalAlignment="Stretch" VerticalAlignment="Center"/>
                    </Grid>
                    <Grid ColumnSpacing="16" Padding="16,8,8,8" BorderThickness="1,1,1,0" CornerRadius="0,0,0,0" HorizontalAlignment="Stretch" VerticalAlignment="Top"
                          Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="2*" MaxWidth="232"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Uid="AddingShortcutCategoryTextBlock" FontSize="14" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                        <AutoSuggestBox x:Name="AddingShortcutCategoryTextBox" x:Uid="AddingShortcutCategoryTextBox" Grid.Column="1" GotFocus="AddingShortcutCategoryTextBox_GotFocus" MaxSuggestionListHeight="128" ItemsSource="{x:Bind ViewModel.ShortcutCategories,Mode=OneWay}" FontSize="14" Height="34" HorizontalAlignment="Stretch" VerticalAlignment="Center"/>
                    </Grid>
                    <Grid ColumnSpacing="16" Padding="16,8,8,8" BorderThickness="1,1,1,1" CornerRadius="0,0,8,8" HorizontalAlignment="Stretch" VerticalAlignment="Top"
                          Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="2*" MaxWidth="128"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Uid="AddingShortcutColorTextBlock" FontSize="14" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                        <ComboBox x:Name="AddingShortcutColorComboBox" Grid.Column="1" Height="34" SelectedIndex="4" HorizontalAlignment="Stretch" VerticalAlignment="Center">
                            <ComboBoxItem>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Ellipse Height="12" Width="12" Fill="Firebrick" Margin="0,1,0,-1" VerticalAlignment="Center"/>
                                    <TextBlock x:Uid="AddingShortcutColorRedTextBlock" VerticalAlignment="Center"/>
                                </StackPanel>
                            </ComboBoxItem>
                            <ComboBoxItem>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Ellipse Height="12" Width="12" Fill="Tomato" Margin="0,1,0,-1" VerticalAlignment="Center"/>
                                    <TextBlock x:Uid="AddingShortcutColorOrangeTextBlock" VerticalAlignment="Center"/>
                                </StackPanel>
                            </ComboBoxItem>
                            <ComboBoxItem>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Ellipse Height="12" Width="12" Fill="Goldenrod" Margin="0,1,0,-1" VerticalAlignment="Center"/>
                                    <TextBlock x:Uid="AddingShortcutColorYellowTextBlock" VerticalAlignment="Center"/>
                                </StackPanel>
                            </ComboBoxItem>
                            <ComboBoxItem>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Ellipse Height="12" Width="12" Fill="ForestGreen" Margin="0,1,0,-1" VerticalAlignment="Center"/>
                                    <TextBlock x:Uid="AddingShortcutColorGreenTextBlock" VerticalAlignment="Center"/>
                                </StackPanel>
                            </ComboBoxItem>
                            <ComboBoxItem>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Ellipse Height="12" Width="12" Fill="DodgerBlue" Margin="0,1,0,-1" VerticalAlignment="Center"/>
                                    <TextBlock x:Uid="AddingShortcutColorBlueTextBlock" VerticalAlignment="Center"/>
                                </StackPanel>
                            </ComboBoxItem>
                            <ComboBoxItem>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Ellipse Height="12" Width="12" Fill="Orchid" Margin="0,1,0,-1" VerticalAlignment="Center"/>
                                    <TextBlock x:Uid="AddingShortcutColorPurpleTextBlock" VerticalAlignment="Center"/>
                                </StackPanel>
                            </ComboBoxItem>
                            <ComboBoxItem>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Ellipse Height="12" Width="12" Fill="DeepPink" Margin="0,1,0,-1" VerticalAlignment="Center"/>
                                    <TextBlock x:Uid="AddingShortcutColorPinkTextBlock" VerticalAlignment="Center"/>
                                </StackPanel>
                            </ComboBoxItem>
                            <ComboBoxItem>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Ellipse Height="12" Width="12" Fill="Sienna" Margin="0,1,0,-1" VerticalAlignment="Center"/>
                                    <TextBlock x:Uid="AddingShortcutColorBrownTextBlock" VerticalAlignment="Center"/>
                                </StackPanel>
                            </ComboBoxItem>
                            <ComboBoxItem>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Ellipse Height="12" Width="12" Fill="DimGray" Margin="0,1,0,-1" VerticalAlignment="Center"/>
                                    <TextBlock x:Uid="AddingShortcutColorGrayTextBlock" VerticalAlignment="Center"/>
                                </StackPanel>
                            </ComboBoxItem>
                        </ComboBox>
                    </Grid>

                    <Border Height="8"/>

                    <Grid ColumnSpacing="16" Padding="16,8" BorderThickness="1,1,1,0" CornerRadius="8,8,0,0" HorizontalAlignment="Stretch" VerticalAlignment="Top"
                          Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                        <CheckBox x:Name="AddingShortcutRunasCheckBox" x:Uid="AddingShortcutRunasCheckBox" IsChecked="False" HorizontalAlignment="Left" Checked="AddingShortcutRunasCheckBox_Checked" Unchecked="AddingShortcutRunasCheckBox_Unchecked"/>
                    </Grid>
                    <Grid ColumnSpacing="16" Padding="16,8" BorderThickness="1,1,1,0" CornerRadius="0,0,0,0" HorizontalAlignment="Stretch" VerticalAlignment="Top"
                          Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                        <CheckBox x:Name="AddingShortcutNoWindowCheckBox" x:Uid="AddingShortcutNoWindowCheckBox" IsChecked="False" HorizontalAlignment="Left"/>
                    </Grid>
                    <Grid ColumnSpacing="16" Padding="16,8" BorderThickness="1,1,1,1" CornerRadius="0,0,8,8" HorizontalAlignment="Stretch" VerticalAlignment="Top"
                          Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                        <CheckBox x:Name="AddingShortcutJumpListCheckBox" x:Uid="AddingShortcutJumpListCheckBox" IsChecked="False" HorizontalAlignment="Left"/>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <Grid Grid.Row="1" BorderBrush="{ThemeResource ControlElevationBorderBrush}" BorderThickness="0,1,0,0" Padding="16" HorizontalAlignment="Stretch">
            <Button x:Name="ViewButton" Padding="24,10" Click="ViewButton_Click">
                <StackPanel Orientation="Horizontal">
                    <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xE8E5;" FontSize="15" Margin="0,0,6,0" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <TextBlock x:Name="ViewTextBlock" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <StackPanel Orientation="Horizontal" Spacing="16" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button x:Name="ResetButton" Padding="24,10" Click="ResetButton_Click">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xE72C;" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <TextBlock x:Uid="PropertyEditResetTextBlock" LineHeight="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button x:Name="EditButton" Padding="24,10" Click="EditButton_Click" Style="{ThemeResource AccentButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon FontFamily="{ThemeResource SymbolThemeFontFamily}" Glyph="&#xE70F;" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <TextBlock x:Uid="PropertyEditSaveTextBlock" LineHeight="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
